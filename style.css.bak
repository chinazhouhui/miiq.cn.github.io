/* 全局样式 */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
    background: linear-gradient(135deg, #ffffff 0%, #f8f9fc 100%);
    color: #333;
    line-height: 1.6;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

/* 导航栏 */
.navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(100, 100, 100, 0.1);
    padding: 15px 0;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
}

.nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 24px;
    font-weight: 700;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.logo-icon {
    font-size: 28px;
}

.nav-menu {
    display: flex;
    list-style: none;
    gap: 40px;
}

.nav-menu a {
    text-decoration: none;
    color: #333;
    font-weight: 500;
    transition: all 0.3s ease;
    position: relative;
}

.nav-menu a:hover {
    color: #667eea;
}

.nav-menu a::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, #667eea, #764ba2);
    transition: width 0.3s ease;
}

.nav-menu a:hover::after {
    width: 100%;
}

.contact-btn {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 600;
}

/* 英雄区 */
.hero {
    margin-top: 70px;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 60px 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 249, 252, 0.9) 100%);
    position: relative;
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -50%;
    width: 1000px;
    height: 1000px;
    background: radial-gradient(circle, rgba(102, 126, 234, 0.1) 0%, transparent 70%);
    border-radius: 50%;
    animation: float 20s ease-in-out infinite;
}

.hero::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -20%;
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(118, 75, 162, 0.1) 0%, transparent 70%);
    border-radius: 50%;
    animation: float-reverse 25s ease-in-out infinite;
}

.hero-content {
    flex: 1;
    z-index: 2;
}

.hero-title {
    font-size: 72px;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 30px;
    color: #1a1a1a;
}

.title-part-1 {
    display: block;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: fadeInUp 0.8s ease-out;
}

.title-part-2 {
    display: block;
    color: #1a1a1a;
    animation: fadeInUp 0.8s ease-out 0.2s both;
}

.hero-subtitle {
    font-size: 22px;
    color: #666;
    margin-bottom: 40px;
    animation: fadeInUp 0.8s ease-out 0.4s both;
}

.hero-buttons {
    display: flex;
    gap: 20px;
    animation: fadeInUp 0.8s ease-out 0.6s both;
}

.btn {
    padding: 14px 40px;
    border: none;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    text-align: center;
}

.btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
}

.btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 40px rgba(102, 126, 234, 0.4);
}

.btn-secondary {
    background: white;
    color: #667eea;
    border: 2px solid #667eea;
}

.btn-secondary:hover {
    background: #f5f7ff;
    transform: translateY(-3px);
}

.btn-outline {
    background: transparent;
    color: #667eea;
    border: 2px solid #667eea;
    padding: 10px 25px;
    font-size: 14px;
}

.btn-outline:hover {
    background: #f5f7ff;
}

/* 英雄区视觉部分 */
.hero-visual {
    flex: 1;
    position: relative;
    height: 500px;
    z-index: 2;
}

.gradient-blob {
    position: absolute;
    border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    opacity: 0.1;
    animation: morph 8s ease-in-out infinite;
}

.blob-1 {
    width: 400px;
    height: 400px;
    top: 0;
    right: 0;
    animation: morph 8s ease-in-out infinite;
}

.blob-2 {
    width: 300px;
    height: 300px;
    bottom: 50px;
    left: 50px;
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    animation: morph 10s ease-in-out infinite 1s;
}

.computer-device {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 350px;
    height: 280px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 30px;
    box-shadow: 0 30px 60px rgba(102, 126, 234, 0.3);
    animation: float 6s ease-in-out infinite;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 120px;
}

@keyframes morph {
    0%, 100% {
        border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
    }
    50% {
        border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
    }
}

@keyframes float {
    0%, 100% {
        transform: translate(-50%, -50%) translateY(0);
    }
    50% {
        transform: translate(-50%, -50%) translateY(-30px);
    }
}

@keyframes float-reverse {
    0%, 100% {
        transform: translateY(0);
    }
    50% {
        transform: translateY(30px);
    }
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* 产品区 */
.products {
    padding: 100px 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(248, 249, 252, 0.5) 100%);
}

.section-title {
    font-size: 48px;
    font-weight: 800;
    text-align: center;
    margin-bottom: 15px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.section-subtitle {
    text-align: center;
    color: #999;
    font-size: 18px;
    margin-bottom: 60px;
}

.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
}

.product-card {
    background: white;
    border-radius: 20px;
    padding: 30px;
    text-align: center;
    transition: all 0.3s ease;
    border: 1px solid rgba(200, 200, 200, 0.2);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
}

.product-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 50px rgba(102, 126, 234, 0.2);
    border-color: rgba(102, 126, 234, 0.3);
}

.product-image {
    width: 120px;
    height: 120px;
    margin: 0 auto 20px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 60px;
}

.product-image.gaming {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.product-image.design {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.product-image.business {
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.product-image.server {
    background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.product-card h3 {
    font-size: 20px;
    margin-bottom: 12px;
    color: #1a1a1a;
}

.product-card p {
    color: #666;
    margin-bottom: 20px;
    font-size: 14px;
}

.product-specs {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-bottom: 20px;
    flex-wrap: wrap;
}

.spec {
    background: #f5f7ff;
    color: #667eea;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
}

/* 特性区 */
.features {
    padding: 100px 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(240, 243, 255, 0.9) 100%);
}

.features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
}

.feature-item {
    text-align: center;
    animation: fadeInUp 0.8s ease-out;
}

.feature-item:nth-child(1) { animation-delay: 0s; }
.feature-item:nth-child(2) { animation-delay: 0.1s; }
.feature-item:nth-child(3) { animation-delay: 0.2s; }
.feature-item:nth-child(4) { animation-delay: 0.3s; }
.feature-item:nth-child(5) { animation-delay: 0.4s; }
.feature-item:nth-child(6) { animation-delay: 0.5s; }

.feature-icon {
    width: 100px;
    height: 100px;
    margin: 0 auto 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 50px;
    color: white;
}

.gradient-icon-1 {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.gradient-icon-2 {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.gradient-icon-3 {
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.gradient-icon-4 {
    background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.gradient-icon-5 {
    background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.gradient-icon-6 {
    background: linear-gradient(135deg, #30cfd0 0%, #330867 100%);
}

.feature-item h3 {
    font-size: 20px;
    margin-bottom: 12px;
    color: #1a1a1a;
}

.feature-item p {
    color: #666;
    font-size: 15px;
}

/* 统计区 */
.stats {
    padding: 80px 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 40px;
}

.stat-card {
    text-align: center;
    color: white;
}

.stat-card h3 {
    font-size: 44px;
    font-weight: 800;
    margin-bottom: 10px;
}

.stat-card p {
    font-size: 18px;
    opacity: 0.9;
}

/* 关于区 */
.about {
    padding: 100px 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 249, 252, 0.9) 100%);
}

.about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
}

.about-text h2 {
    font-size: 44px;
    font-weight: 800;
    margin-bottom: 30px;
    color: #1a1a1a;
}

.about-text p {
    color: #666;
    margin-bottom: 20px;
    font-size: 16px;
    line-height: 1.8;
}

.about-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    margin-top: 30px;
}

.about-feature {
    background: linear-gradient(135deg, #f5f7ff 0%, #e8f0ff 100%);
    padding: 15px 20px;
    border-radius: 10px;
    font-weight: 600;
    color: #667eea;
}

.about-visual {
    position: relative;
    height: 400px;
}

.blob-3 {
    width: 400px;
    height: 400px;
    position: absolute;
    top: 0;
    right: 0;
    animation: morph 8s ease-in-out infinite;
}

.blob-4 {
    width: 300px;
    height: 300px;
    position: absolute;
    bottom: 0;
    left: 0;
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    animation: morph 10s ease-in-out infinite 1s;
}

/* 联系区 */
.contact {
    padding: 100px 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(240, 243, 255, 0.9) 100%);
}

.contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    margin: 60px 0;
}

.contact-item {
    background: white;
    padding: 30px;
    border-radius: 15px;
    text-align: center;
    border: 1px solid rgba(200, 200, 200, 0.2);
}

.contact-icon {
    font-size: 40px;
    margin-bottom: 15px;
}

.contact-item h3 {
    font-size: 18px;
    margin-bottom: 10px;
    color: #1a1a1a;
}

.contact-item p {
    color: #666;
    font-size: 14px;
}

.contact-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 600px;
    margin: 40px auto;
}

.contact-form input,
.contact-form textarea {
    grid-column: span 1;
    padding: 15px;
    border: 1px solid #ddd;
    border-radius: 10px;
    font-size: 14px;
    font-family: inherit;
    transition: all 0.3s ease;
}

.contact-form textarea {
    grid-column: span 2;
    resize: none;
}

.contact-form input:focus,
.contact-form textarea:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.contact-form button {
    grid-column: span 2;
}

/* 页脚 */
.footer {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    color: white;
    padding: 60px 0 20px;
}

.footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 40px;
    margin-bottom: 40px;
}

.footer-section h4 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 20px;
    color: #fff;
}

.footer-section ul {
    list-style: none;
}

.footer-section li {
    margin-bottom: 12px;
}

.footer-section a {
    color: #aaa;
    text-decoration: none;
    transition: color 0.3s ease;
    font-size: 14px;
}

.footer-section a:hover {
    color: #667eea;
}

.social-links {
    display: flex;
    gap: 15px;
}

.social-links a {
    display: inline-block;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}

.social-links a:hover {
    background: #667eea;
    color: white;
}

.footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 30px;
    text-align: center;
    color: #888;
    font-size: 14px;
}

/* 响应式设计 */
@media (max-width: 768px) {
    .hero {
        flex-direction: column;
        text-align: center;
        padding: 40px 0;
    }

    .hero-title {
        font-size: 42px;
    }

    .hero-subtitle {
        font-size: 18px;
    }

    .hero-buttons {
        justify-content: center;
        flex-wrap: wrap;
    }

    .hero-visual {
        height: 300px;
        margin-top: 40px;
    }

    .nav-menu {
        gap: 20px;
        font-size: 14px;
    }

    .products-grid,
    .features-grid,
    .stats-grid,
    .contact-grid {
        grid-template-columns: 1fr;
    }

    .about-content {
        grid-template-columns: 1fr;
    }

    .section-title {
        font-size: 36px;
    }

    .contact-form {
        grid-template-columns: 1fr;
    }

    .contact-form textarea,
    .contact-form button {
        grid-column: span 1;
    }

    .title-part-1,
    .title-part-2 {
        display: inline;
    }
}

@media (max-width: 480px) {
    .navbar {
        padding: 10px 0;
    }

    .nav-menu {
        gap: 10px;
        font-size: 12px;
    }

    .hero-title {
        font-size: 32px;
    }

    .section-title {
        font-size: 28px;
    }

    .hero-buttons {
        flex-direction: column;
        gap: 15px;
    }

    .btn {
        padding: 12px 30px;
        font-size: 14px;
    }
}

/* ========== 其他页面样式 ========== */

/* 页面头部 */
.page-hero {
    margin-top: 70px;
    padding: 60px 0;
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(240, 243, 255, 0.5) 100%);
    text-align: center;
    border-bottom: 1px solid rgba(200, 200, 200, 0.1);
}

.page-hero h1 {
    font-size: 48px;
    font-weight: 800;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 15px;
}

.page-hero p {
    font-size: 18px;
    color: #666;
}

/* 产品详情页 */
.products-detail {
    padding: 80px 0;
}

.product-category {
    margin-bottom: 80px;
}

.category-header {
    text-align: center;
    margin-bottom: 50px;
}

.category-header h2 {
    font-size: 36px;
    font-weight: 800;
    margin-bottom: 12px;
    color: #1a1a1a;
}

.category-header p {
    font-size: 16px;
    color: #666;
}

.product-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
}

.product-item {
    background: white;
    border-radius: 15px;
    padding: 25px;
    text-align: center;
    border: 1px solid rgba(200, 200, 200, 0.2);
    transition: all 0.3s ease;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.05);
}

.product-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 40px rgba(102, 126, 234, 0.2);
    border-color: rgba(102, 126, 234, 0.3);
}

.product-image-box {
    width: 100%;
    height: 120px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    font-size: 12px;
    color: white;
    font-weight: 600;
}

.product-item h3 {
    font-size: 18px;
    margin-bottom: 10px;
    color: #1a1a1a;
}

.product-item p {
    color: #666;
    font-size: 14px;
    margin-bottom: 15px;
}

.product-desc {
    background: #f5f7ff;
    padding: 10px;
    border-radius: 8px;
    margin-bottom: 15px !important;
}

.product-price {
    font-size: 20px;
    font-weight: 700;
    color: #667eea;
    margin-bottom: 15px !important;
}

/* 维修页面 */
.repair-detail {
    padding: 80px 0;
}

.repair-section {
    margin-bottom: 60px;
    background: white;
    padding: 40px;
    border-radius: 20px;
    border: 1px solid rgba(200, 200, 200, 0.1);
}

.repair-section h2 {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 30px;
    color: #1a1a1a;
    border-bottom: 3px solid #667eea;
    padding-bottom: 15px;
}

.repair-steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
}

.step {
    text-align: center;
    padding: 30px 20px;
    background: linear-gradient(135deg, #f5f7ff 0%, #e8f0ff 100%);
    border-radius: 15px;
    transition: all 0.3s ease;
}

.step:hover {
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.2);
    transform: translateY(-5px);
}

.step-number {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 24px;
    margin: 0 auto 15px;
}

.step h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 10px;
    color: #1a1a1a;
}

.step p {
    font-size: 13px;
    color: #666;
}

.repair-services {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
}

.service-category {
    background: linear-gradient(135deg, #f5f7ff 0%, #e8f0ff 100%);
    padding: 25px;
    border-radius: 15px;
    border-left: 4px solid #667eea;
}

.service-category h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 15px;
    color: #667eea;
}

.service-category ul {
    list-style: none;
}

.service-category li {
    padding: 8px 0;
    color: #666;
    font-size: 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.5);
}

.service-category li:last-child {
    border-bottom: none;
}

.warranty-info {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 25px;
}

.warranty-item {
    background: linear-gradient(135deg, #f5f7ff 0%, #e8f0ff 100%);
    padding: 25px;
    border-radius: 15px;
    border-left: 4px solid #667eea;
}

.warranty-item h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
    color: #667eea;
}

.warranty-item p {
    color: #666;
    font-size: 14px;
    line-height: 1.8;
}

.warranty-item strong {
    color: #667eea;
    font-weight: 700;
}

.price-table {
    overflow-x: auto;
    margin: 30px 0;
}

table {
    width: 100%;
    border-collapse: collapse;
    background: white;
}

table th {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 15px;
    text-align: left;
    font-weight: 600;
}

table td {
    padding: 15px;
    border-bottom: 1px solid #eee;
    color: #666;
}

table tbody tr:hover {
    background: #f9f9f9;
}

.price-note {
    color: #999;
    font-size: 12px;
    margin-top: 15px;
}

.appointment-form {
    display: grid;
    gap: 15px;
}

.appointment-form .form-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
}

.appointment-form input,
.appointment-form textarea {
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
    transition: all 0.3s ease;
}

.appointment-form input:focus,
.appointment-form textarea:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.appointment-form textarea {
    grid-column: span 2;
    resize: none;
}

/* 关于页面 */
.about-detail {
    padding: 80px 0;
}

.about-section {
    margin-bottom: 60px;
    background: white;
    padding: 40px;
    border-radius: 20px;
    border: 1px solid rgba(200, 200, 200, 0.1);
}

.about-section h2 {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 30px;
    color: #1a1a1a;
    border-bottom: 3px solid #667eea;
    padding-bottom: 15px;
}

.section-content p {
    color: #666;
    font-size: 15px;
    margin-bottom: 15px;
    line-height: 1.8;
}

.mission {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(240, 243, 255, 0.5) 100%);
    border: 2px solid rgba(102, 126, 234, 0.2);
}

.mission-items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
}

.mission-item {
    background: white;
    padding: 25px;
    border-radius: 15px;
    border-left: 4px solid #667eea;
}

.mission-item h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
    color: #667eea;
}

.mission-item p {
    color: #666;
    font-size: 14px;
    margin: 0;
}

.advantages {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 25px;
}

.advantage-item {
    background: linear-gradient(135deg, #f5f7ff 0%, #e8f0ff 100%);
    padding: 30px;
    border-radius: 15px;
    text-align: center;
    border: 1px solid rgba(102, 126, 234, 0.2);
    transition: all 0.3s ease;
}

.advantage-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.2);
}

.advantage-icon {
    font-size: 40px;
    margin-bottom: 15px;
}

.advantage-item h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 10px;
    color: #1a1a1a;
}

.advantage-item p {
    color: #666;
    font-size: 14px;
    margin: 0;
}

.honors {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 25px;
}

.honor-item {
    background: linear-gradient(135deg, #fff5e1 0%, #ffe8cc 100%);
    padding: 30px;
    border-radius: 15px;
    text-align: center;
    border: 2px solid #ffc107;
}

.honor-badge {
    font-size: 28px;
    display: block;
    margin-bottom: 10px;
}

.honor-item p {
    color: #333;
    font-weight: 600;
    margin: 0;
}

.company-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 20px;
}

.stat {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 30px;
    border-radius: 15px;
    text-align: center;
}

.stat-number {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 10px;
}

.stat-label {
    font-size: 14px;
    opacity: 0.9;
}

.recruitment {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(240, 243, 255, 0.5) 100%);
    border: 2px solid rgba(102, 126, 234, 0.2);
}

.recruitment p {
    color: #666;
    font-size: 15px;
    margin-bottom: 25px;
}

.job-positions {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
    margin: 30px 0;
}

.job-item {
    background: white;
    padding: 25px;
    border-radius: 15px;
    border: 1px solid rgba(200, 200, 200, 0.2);
}

.job-item h3 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 12px;
    color: #667eea;
}

.job-item p {
    color: #666;
    font-size: 13px;
    margin: 8px 0;
}

.apply-info {
    text-align: center;
    color: #666;
}

.apply-info a {
    color: #667eea;
    text-decoration: none;
    font-weight: 600;
}

/* FAQ页面 */
.faq-detail {
    padding: 80px 0;
}

.faq-category {
    margin-bottom: 50px;
}

.faq-category h2 {
    font-size: 28px;
    font-weight: 800;
    margin-bottom: 30px;
    color: #1a1a1a;
    border-left: 4px solid #667eea;
    padding-left: 15px;
}

.faq-items {
    display: grid;
    gap: 20px;
}

.faq-item {
    background: white;
    border-radius: 15px;
    border: 1px solid rgba(200, 200, 200, 0.1);
    overflow: hidden;
    transition: all 0.3s ease;
}

.faq-item:hover {
    box-shadow: 0 5px 20px rgba(102, 126, 234, 0.1);
}

.faq-question {
    padding: 25px;
    background: linear-gradient(135deg, #f5f7ff 0%, #e8f0ff 100%);
    cursor: pointer;
    user-select: none;
}

.faq-question h3 {
    font-size: 16px;
    font-weight: 700;
    color: #667eea;
    margin: 0;
}

.faq-answer {
    padding: 25px;
    border-top: 1px solid rgba(200, 200, 200, 0.1);
}

.faq-answer p {
    color: #666;
    font-size: 14px;
    margin: 0;
    line-height: 1.8;
}

.faq-section {
    background: white;
    padding: 40px;
    border-radius: 20px;
    border: 1px solid rgba(200, 200, 200, 0.1);
    margin-top: 50px;
}

.faq-section h2 {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 30px;
    color: #1a1a1a;
    border-bottom: 3px solid #667eea;
    padding-bottom: 15px;
}

.faq-section p {
    color: #666;
    font-size: 15px;
    margin-bottom: 20px;
}

.contact-support {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(240, 243, 255, 0.5) 100%);
    border: 2px solid rgba(102, 126, 234, 0.2);
}

.contact-methods {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 25px;
    margin-top: 30px;
}

.method {
    background: white;
    padding: 25px;
    border-radius: 15px;
    text-align: center;
    border-left: 4px solid #667eea;
}

.method h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 10px;
    color: #1a1a1a;
}

.method p {
    color: #666;
    font-size: 14px;
    margin: 8px 0;
}

.tip {
    font-size: 12px;
    color: #999;
}

/* 联系页面 */
.contact-detail {
    padding: 80px 0;
}

.contact-info-section {
    margin-bottom: 60px;
}

.contact-info-section h2 {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 40px;
    text-align: center;
    color: #1a1a1a;
}

.contact-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
}

.contact-info-item {
    background: linear-gradient(135deg, #f5f7ff 0%, #e8f0ff 100%);
    padding: 30px;
    border-radius: 15px;
    text-align: center;
    border: 1px solid rgba(102, 126, 234, 0.2);
    transition: all 0.3s ease;
}

.contact-info-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.2);
}

.info-icon {
    font-size: 40px;
    margin-bottom: 15px;
}

.contact-info-item h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
    color: #1a1a1a;
}

.main-info {
    font-size: 16px;
    font-weight: 600;
    color: #667eea;
    margin: 10px 0 5px;
}

.sub-info {
    font-size: 12px;
    color: #999;
    margin: 5px 0 0;
}

.contact-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-bottom: 60px;
}

.contact-form-section {
    background: white;
    padding: 40px;
    border-radius: 20px;
    border: 1px solid rgba(200, 200, 200, 0.1);
}

.contact-form-section h2 {
    font-size: 28px;
    font-weight: 800;
    margin-bottom: 25px;
    color: #1a1a1a;
}

.contact-form-full {
    display: grid;
    gap: 20px;
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}

.form-group {
    display: grid;
    gap: 8px;
}

.form-group label {
    font-weight: 600;
    color: #1a1a1a;
    font-size: 14px;
}

.form-group input,
.form-group textarea {
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
    transition: all 0.3s ease;
}

.form-group input:focus,
.form-group textarea:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.form-group textarea {
    resize: none;
    font-family: inherit;
}

.form-group input[type="checkbox"] {
    width: auto;
    margin-right: 8px;
}

.btn-large {
    padding: 16px 40px;
    font-size: 16px;
    width: 100%;
}

.contact-map-section {
    background: white;
    padding: 40px;
    border-radius: 20px;
    border: 1px solid rgba(200, 200, 200, 0.1);
}

.contact-map-section h2 {
    font-size: 28px;
    font-weight: 800;
    margin-bottom: 25px;
    color: #1a1a1a;
}

.map-placeholder {
    background: linear-gradient(135deg, #f5f7ff 0%, #e8f0ff 100%);
    border-radius: 15px;
    border: 2px solid rgba(102, 126, 234, 0.2);
    padding: 60px 20px;
    text-align: center;
    margin-bottom: 25px;
}

.map-content p {
    color: #666;
    margin: 5px 0;
    font-size: 14px;
}

.map-content strong {
    color: #667eea;
    font-weight: 700;
}

.info-boxes {
    display: grid;
    gap: 15px;
}

.info-box {
    background: linear-gradient(135deg, #f5f7ff 0%, #e8f0ff 100%);
    padding: 20px;
    border-radius: 12px;
    border-left: 4px solid #667eea;
}

.info-box h4 {
    font-size: 16px;
    font-weight: 700;
    color: #667eea;
    margin-bottom: 12px;
}

.info-box ul {
    list-style: none;
}

.info-box li {
    color: #666;
    font-size: 13px;
    padding: 5px 0;
}

.service-area {
    background: white;
    padding: 40px;
    border-radius: 20px;
    border: 1px solid rgba(200, 200, 200, 0.1);
    margin-bottom: 50px;
}

.service-area h2 {
    font-size: 28px;
    font-weight: 800;
    margin-bottom: 15px;
    color: #1a1a1a;
}

.service-area > p {
    color: #666;
    font-size: 15px;
    margin-bottom: 20px;
}

.area-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
}

.area-tag {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 10px 18px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
}

.area-note {
    color: #999;
    font-size: 12px;
    margin-top: 15px;
}

.faq-quick-links {
    background: white;
    padding: 40px;
    border-radius: 20px;
    border: 1px solid rgba(200, 200, 200, 0.1);
}

.faq-quick-links h2 {
    font-size: 28px;
    font-weight: 800;
    margin-bottom: 30px;
    text-align: center;
    color: #1a1a1a;
}

.quick-link-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

.quick-link {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 25px;
    border-radius: 15px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    transition: all 0.3s ease;
}

.quick-link:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(102, 126, 234, 0.3);
}

.link-icon {
    font-size: 32px;
}

.link-text {
    font-weight: 600;
    font-size: 16px;
}

/* 响应式设计优化 */
@media (max-width: 768px) {
    .contact-content {
        grid-template-columns: 1fr;
    }

    .form-row {
        grid-template-columns: 1fr;
    }

    .repair-steps {
        grid-template-columns: repeat(2, 1fr);
    }

    .mission-items {
        grid-template-columns: 1fr;
    }

    .company-stats {
        grid-template-columns: repeat(2, 1fr);
    }

    .advantages {
        grid-template-columns: 1fr;
    }

    .product-list {
        grid-template-columns: repeat(2, 1fr);
    }

    .repair-services {
        grid-template-columns: 1fr;
    }

    .warranty-info {
        grid-template-columns: 1fr;
    }

    .about-section {
        padding: 25px;
    }

    .repair-section {
        padding: 25px;
    }

    .contact-form-section,
    .contact-map-section {
        padding: 25px;
    }

    .page-hero h1 {
        font-size: 36px;
    }

    .area-tags {
        justify-content: center;
    }
}

@media (max-width: 480px) {
    .repair-steps {
        grid-template-columns: 1fr;
    }

    .company-stats {
        grid-template-columns: 1fr;
    }

    .product-list {
        grid-template-columns: 1fr;
    }

    .page-hero h1 {
        font-size: 28px;
    }

    .quick-link-grid {
        grid-template-columns: 1fr;
    }

    .appointment-form .form-group {
        grid-template-columns: 1fr;
    }

    .appointment-form textarea {
        grid-column: span 1;
    }

    table {
        font-size: 12px;
    }

    table th,
    table td {
        padding: 10px;
    }
}

